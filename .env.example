VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key
VITE_KAKAO_TOKEN_EXCHANGE_ENDPOINT=https://your-cloud-run-url/api/auth/kakao/exchange
VITE_KAKAO_REDIRECT_ORIGIN=https://unwoldang.com
VITE_KAKAO_SCOPES=

# demo | test | live
VITE_PAYMENT_MODE=live
VITE_PORTONE_STORE_ID=store-your-portone-store-id
VITE_PORTONE_CHANNEL_KEY=channel-key-for-kg-inicis
VITE_PORTONE_CONFIRM_ENDPOINT=https://your-cloud-run-url/api/payments/portone/confirm
VITE_PORTONE_DEFAULT_PHONE_NUMBER=01000000000
VITE_PORTONE_DEFAULT_EMAIL=customer@unwoldang.com

VITE_REPORT_ENDPOINT=https://your-cloud-run-url/api/report
VITE_REPORT_TIMEOUT_MS=70000

# Production admin must stay disabled until a server-authenticated admin API is connected.
VITE_ENABLE_CLIENT_ADMIN=false
VITE_LOCAL_ADMIN_CREDENTIAL_HASH=

# server-side only, set these in Cloud Run Secret Manager / env, never in Vercel client env
PORTONE_API_SECRET=your_portone_v2_api_secret
PORTONE_STORE_ID=store-your-portone-store-id
PORTONE_API_BASE_URL=https://api.portone.io
REPORT_ACCESS_SECRET=replace_with_a_long_random_secret_value
REPORT_ACCESS_TOKEN_TTL_MS=1800000
REPORT_RATE_LIMIT_WINDOW_MS=60000
REPORT_RATE_LIMIT_MAX=12
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret_if_enabled
